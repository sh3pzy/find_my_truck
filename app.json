{
  "expo": {
    "name": "FindMyTruck",
    "slug": "FindMyTruck",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/minimal_pin/images/ios-app-icon.png",
    "scheme": "findmytruck",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "icon": "./assets/minimal_pin/images/ios-app-icon.png"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#FFF9F0",
        "foregroundImage": "./assets/minimal_pin/android_icons/android-icon-foreground.png",
        "monochromeImage": "./assets/minimal_pin/android_icons/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#208AEF",
          "android": {
            "image": "./assets/images/splash-icon.png",
            "imageWidth": 76
          }
        }
      ],
      "expo-font"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": false
    }
  }
}
